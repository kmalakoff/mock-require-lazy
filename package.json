{
  "name": "mock-require-lazy",
  "version": "1.0.0",
  "description": "Simple, intuitive mocking of Node.js modules. Fork of mock-require adding lazy require and is a drop in replacement for mock-require",
  "keywords": [
    "require",
    "dependency",
    "injection",
    "di",
    "inject",
    "swap",
    "test",
    "mock",
    "stub",
    "mock-require",
    "lazy"
  ],
  "homepage": "https://github.com/kmalakoff/mock-require-lazy",
  "bugs": {
    "url": "https://github.com/kmalakoff/mock-require-lazy/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kmalakoff/mock-require-lazy.git"
  },
  "license": "MIT",
  "author": "Kevin Malakoff <kmalakoff@gmail.com>",
  "main": "index.js",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint .",
    "test": "cross-env NODE_PATH=test/data/node-path mocha-compat test/spec/**/*.test.js",
    "prepublishOnly": "dtd \"npm run lint\" \"depcheck --ignores='depcheck'\""
  },
  "dependencies": {
    "get-caller-file": "^2.0.5",
    "normalize-path": "^3.0.0"
  },
  "devDependencies": {
    "babel-eslint": "^10.1.0",
    "cross-env": "^2.0.1",
    "depcheck": "^0.9.2",
    "dis-dat": "^0.1.3",
    "eslint": "^6.8.0",
    "eslint-config-prettier": "^6.11.0",
    "eslint-config-standard": "^14.1.1",
    "eslint-plugin-import": "^2.20.2",
    "eslint-plugin-node": "^11.1.0",
    "eslint-plugin-promise": "^4.2.1",
    "eslint-plugin-standard": "^4.0.1",
    "mocha-compat": "^3.5.5",
    "prettier": "^2.0.5"
  },
  "engines": {
    "node": ">=0.8"
  }
}
